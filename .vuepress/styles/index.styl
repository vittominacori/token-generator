.theme-container
    .hero
        #main-title
            color #0d6387
        img
            border-radius 50%
            max-height 200px !important

    .navbar .site-name
        display none

    .token-spec-actions
        display flex
        flex-wrap wrap
        gap 0.75rem
        margin-top 2.5rem
        padding-top 1.5rem
        border-top 1px solid #eaecef

    .token-spec-action
        display inline-flex
        align-items center
        justify-content center
        min-height 2.5rem
        padding 0 1rem
        border 1px solid #3eaf7c
        border-radius 4px
        color #3eaf7c
        font-weight 600

        &:hover
            text-decoration none !important
            color #2c815c
            border-color #2c815c

    .token-spec-action-primary
        color #fff
        background #3eaf7c

        &:hover
            color #fff
            background #2c815c
